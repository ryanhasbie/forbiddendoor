<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= mode === 'register' ? 'Daftar' : 'Login' %> - TebakBola</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="auth-body">
  <div class="auth-wrapper">
    <div class="auth-hero">
      <div class="auth-hero-inner">
        <span class="auth-logo">⚽</span>
        <h1>TebakBola</h1>
        <p>Pasang koin · Tebak pemenang · Menang hadiah</p>
        <ul class="auth-features">
          <li>🎯 Tebakan bola real-time</li>
          <li>💳 Top-up & redeem koin</li>
          <li><a href="<%= PATH.leaderboard %>">🏆 Leaderboard kompetitif</a></li>
        </ul>
      </div>
    </div>

    <main class="auth-panel">
      <div class="auth-card-v2">
        <div class="auth-tabs">
          <a href="<%= PATH.login %>" class="auth-tab <%= mode === 'login' ? 'active' : '' %>">Login</a>
          <% if (registrationOpen) { %>
            <a href="<%= PATH.register %>" class="auth-tab <%= mode === 'register' ? 'active' : '' %>">Daftar</a>
          <% } else { %>
            <span class="auth-tab auth-tab-disabled" title="Kuota pendaftaran penuh">Daftar (Penuh)</span>
          <% } %>
        </div>

        <% if (error) { %>
          <div class="alert error"><%= error %></div>
        <% } %>

        <% if (mode === 'register') { %>
          <p class="auth-quota">
            Kuota pendaftaran:
            <strong><%= userCount %> / <%= maxUsers %></strong>
            <% if (registrationOpen) { %>
              (tersisa <%= remaining %>)
            <% } else { %>
              — <span class="quota-full">PENUH</span>
            <% } %>
          </p>
          <% if (registrationOpen) { %>
            <form method="post" action="<%= POST.register %>" class="form-stack">
              <%- include('partials/csrf') %>
              <label>Username</label>
              <input name="username" type="text" placeholder="Masukkan username" required autofocus />
              <label>Password</label>
              <input name="password" type="password" placeholder="Minimal 6 karakter" required />
              <button type="submit" class="btn-primary btn-auth">
                Daftar &amp; dapat <%= registerBonus || 30 %> koin
              </button>
            </form>
          <% } else { %>
            <div class="alert error">
              Pendaftaran ditutup. Maksimal <%= maxUsers %> user sudah terdaftar.
            </div>
            <a href="<%= PATH.login %>" class="btn-primary btn-auth" style="display:block;text-align:center;text-decoration:none;">
              Kembali ke Login
            </a>
          <% } %>
        <% } else { %>
          <form method="post" action="<%= POST.login %>" class="form-stack">
            <%- include('partials/csrf') %>
            <label>Username</label>
            <input name="username" type="text" placeholder="Masukkan username" required autofocus />
            <label>Password</label>
            <input name="password" type="password" placeholder="Masukkan password" required />
            <button type="submit" class="btn-primary btn-auth">Masuk</button>
          </form>
        <% } %>
      </div>
      <p class="auth-footer">
        <a href="<%= PATH.leaderboard %>">Leaderboard</a> ·
        <a href="<%= PATH.terms %>">Syarat &amp; Ketentuan</a><br />
        © 2026 TebakBola — Game prediksi hiburan
      </p>
    </main>
  </div>
</body>
</html>